# OpenRouter (openrouter.ai — one key, all models)
OPENROUTER_API_KEY=sk-or-your-api-key-here

# Neo4j Connection Configuration for FastAPI Backend
NEO4J_URI=neo4j+s://your-neo4j-auradb-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Supabase Configuration (Risk Event Logging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
